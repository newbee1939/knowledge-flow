---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate } from '../lib/date';
import { getPosts } from '../lib/posts';
import { buildTimeline } from '../lib/timeline';
import { withBase } from '../lib/url';

// タイムラインは posts からビルド時に導出する（設計原則 Derived-not-Generated）。
// docs/blog/posts/ に md を 1 枚足すだけで、コードを変えずにカードが増える。
const posts = await getPosts();
const timeline = buildTimeline(
	posts.map((post) => ({ id: post.id, date: post.data.date, title: post.data.title })),
);
---

<BaseLayout title="knowledge-flow">
	<section class="hero">
		<h1>knowledge-flow</h1>
		<p>今日のテックを線で理解できる、一人運営のテックニュースメディア。</p>
	</section>

	{
		timeline.map(({ year, months }) => (
			<section class="year">
				<h2 class="year-label">{year}</h2>
				{months.map(({ month, entries }) => (
					<section class="month">
						<h3 class="month-label">{String(month).padStart(2, '0')}</h3>
						<ol class="day-strip">
							{entries.map((entry) => (
								<li class="day-card">
									<a href={withBase(`blog/${entry.id}/`)}>
										<time datetime={entry.date.toISOString()}>{formatDate(entry.date)}</time>
										<span class="day-title">{entry.title}</span>
									</a>
								</li>
							))}
						</ol>
					</section>
				))}
			</section>
		))
	}
</BaseLayout>

<style>
	.hero {
		padding-block: var(--space-xl) var(--space-lg);
	}

	.hero h1 {
		margin: 0;
		font-family: var(--font-mono);
		font-size: var(--text-2xl);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.hero p {
		margin: var(--space-xs) 0 0;
		color: var(--color-text-muted);
		font-size: var(--text-sm);
	}

	.year {
		margin-top: var(--space-xl);
	}

	.year-label {
		margin: 0;
		border-bottom: 1px solid var(--color-border);
		padding-bottom: var(--space-xs);
		font-family: var(--font-mono);
		font-size: var(--text-xl);
		font-weight: 600;
		letter-spacing: 0.04em;
	}

	.month {
		margin-top: var(--space-lg);
	}

	.month-label {
		margin: 0 0 var(--space-sm);
		color: var(--color-text-muted);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		font-weight: 500;
		letter-spacing: 0.08em;
	}

	/* 月ごとの横スクロール領域。カードは日単位 */
	.day-strip {
		display: flex;
		gap: var(--space-sm);
		margin: 0;
		padding: 0 0 var(--space-xs);
		list-style: none;
		overflow-x: auto;
		scroll-snap-type: x proximity;
		scrollbar-width: thin;
	}

	.day-card {
		flex: 0 0 16rem;
		scroll-snap-align: start;
	}

	.day-card a {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		height: 100%;
		border: 1px solid var(--color-border);
		border-radius: 6px;
		padding: var(--space-md);
		text-decoration: none;
		transition:
			border-color 0.15s ease,
			background-color 0.15s ease;
	}

	.day-card a:hover {
		border-color: var(--color-text);
		background: var(--color-surface);
	}

	.day-card time {
		color: var(--color-text-muted);
		font-size: var(--text-xs);
	}

	.day-title {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		overflow: hidden;
		font-size: var(--text-sm);
		font-weight: 500;
		line-height: 1.6;
	}

	@media (max-width: 40rem) {
		.day-card {
			flex-basis: 14rem;
		}
	}
</style>
