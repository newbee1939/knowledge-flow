---
import { withBase } from '../lib/url';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Daily Tech Report' } = Astro.props;
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link
			rel="alternate"
			type="application/rss+xml"
			title="knowledge-flow"
			href={withBase('rss.xml')}
		/>
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="site-name" href={withBase('/')}>knowledge-flow</a>
			<nav class="site-nav">
				<a href={withBase('categories/')}>Categories</a>
				<a href={withBase('rss.xml')}>RSS</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<p>© {new Date().getFullYear()} knowledge-flow — Daily Tech Report</p>
		</footer>
	</body>
</html>

<style>
	.site-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		max-width: var(--container-wide);
		margin-inline: auto;
		padding: var(--space-md) var(--space-lg);
	}

	.site-nav {
		display: flex;
		gap: var(--space-md);
	}

	.site-nav a {
		color: var(--color-text-muted);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		text-decoration: none;
	}

	.site-nav a:hover {
		color: var(--color-accent);
	}

	.site-name {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		font-weight: 600;
		letter-spacing: 0.02em;
		text-decoration: none;
	}

	.site-name:hover {
		color: var(--color-accent);
	}

	main {
		max-width: var(--container-wide);
		margin-inline: auto;
		padding: 0 var(--space-lg) var(--space-2xl);
	}

	.site-footer {
		max-width: var(--container-wide);
		margin-inline: auto;
		padding: var(--space-md) var(--space-lg);
		border-top: 1px solid var(--color-border);
		color: var(--color-text-muted);
		font-size: var(--text-xs);
	}

	@media (max-width: 40rem) {
		.site-header,
		main,
		.site-footer {
			padding-inline: var(--space-md);
		}
	}
</style>
